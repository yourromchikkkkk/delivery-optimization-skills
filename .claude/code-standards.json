        {
          "id": "req.immutable",
          "question": "Immutable data structures by default",
          "type": "yn",
          "suggested": null,
          "override": null,
          "other": null
        },
        {
          "id": "req.other",
          "question": "Other required patterns (one per line)",
          "type": "text",
          "suggested": "Single Responsibility — each module / class has one reason to change\nOpen/Closed — open for extension, closed for modification\nLiskov Substitution — derived types must be substitutable for their base types\nInterface Segregation — many specific interfaces over one large interface\nDependency Inversion — depend on abstractions, never on concretions",
          "override": null,
          "other": null
        }
      ]
    },
